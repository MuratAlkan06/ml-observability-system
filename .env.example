# Copy to .env and fill in real values before `docker compose up`:
#   cp .env.example .env   &&   edit .env
# .env is gitignored — never commit real secrets.

# --- Required ---
# PostgreSQL password. Applied only at first initdb; also threaded into the
# consumer and drift DSNs. Rotating it means recreating the volume:
# `docker compose down -v && docker compose up -d`.
POSTGRES_PASSWORD=change-me-postgres

# Grafana admin password. No default — the stack refuses to start if unset,
# so a weak/default admin password can never silently ship.
GF_ADMIN_PASSWORD=change-me-grafana

# --- Optional ---
# Grafana admin username (defaults to `mlobsadmin` when unset). Avoids the
# well-known `admin` login.
GF_ADMIN_USER=mlobsadmin

# Slack Incoming Webhook for drift alerts. Leave empty to disable alerting —
# the drift job still evaluates and records runs.
SLACK_WEBHOOK_URL=
