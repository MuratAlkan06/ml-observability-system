            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "range": true,
          "instant": false,
          "legendFormat": "p50 {{endpoint}}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(mlobs_http_request_duration_seconds_bucket[$__rate_interval])) by (le, endpoint))",
