      "id": 1,
      "type": "timeseries",
      "title": "Request latency p50 / p95 (by endpoint)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(rate(mlobs_http_request_duration_seconds_bucket[$__rate_interval])) by (le, endpoint))",
