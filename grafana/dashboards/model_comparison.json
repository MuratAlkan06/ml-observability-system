    {
      "id": 1,
      "type": "timeseries",
      "title": "Agreement ratio over time (shadow vs primary label; target 0.90)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(rate(mlobs_shadow_comparisons_total{primary_label=\"positive\",shadow_label=\"positive\"}[$__rate_interval])) + sum(rate(mlobs_shadow_comparisons_total{primary_label=\"negative\",shadow_label=\"negative\"}[$__rate_interval]))) / clamp_min(sum(rate(mlobs_shadow_comparisons_total[$__rate_interval])), 1e-9)",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "range": true,
          "instant": false,
          "legendFormat": "agreement"
        },
        {
          "refId": "B",
          "expr": "vector(0.9)",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "range": true,
          "instant": false,
          "legendFormat": "target 0.90"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
